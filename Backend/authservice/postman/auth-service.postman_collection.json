{
	"info": {
		"_postman_id": "8482b8a7-5d34-4b92-8db4-9d10738a1bb4",
		"name": "Auth Service API",
		"description": "Colección de pruebas para el microservicio de autenticación",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "0. Register Traveler",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set(\"email\", pm.collectionVariables.get(\"register_email\"));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"{{register_first_name}}\",\n  \"last_name\": \"{{register_last_name}}\",\n  \"email\": \"{{register_email}}\",\n  \"phone_number\": \"{{register_phone_number}}\",\n  \"password\": \"{{register_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "0.1 Confirm Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{register_email}}\",\n  \"code\": \"{{verification_code}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register/confirm",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register",
								"confirm"
							]
						}
					},
					"response": []
				},
				{
					"name": "1. Login (JSON)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set(\"access_token\", pm.response.json().access_token);",
									"    pm.collectionVariables.set(\"refresh_token\", pm.response.json().refresh_token);",
									"    pm.collectionVariables.set(\"email\", pm.collectionVariables.get(\"register_email\") || \"admin@hotel.com\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{login_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Login Form",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{email}}",
									"type": "text"
								},
								{
									"key": "password",
									"value": "{{login_password}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/auth/login/form",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login",
								"form"
							]
						}
					},
					"response": []
				},
				{
					"name": "3. Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"me"
							]
						}
					},
					"response": []
				},
				{
					"name": "4. Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{refresh_token}}\",\n  \"email\": \"{{email}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"refresh"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8003",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "refresh_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "email",
			"value": "admin@hotel.com",
			"type": "string"
		},
		{
			"key": "login_password",
			"value": "123456",
			"type": "string"
		},
		{
			"key": "register_first_name",
			"value": "Maria",
			"type": "string"
		},
		{
			"key": "register_last_name",
			"value": "Diaz",
			"type": "string"
		},
		{
			"key": "register_email",
			"value": "maria+travelhub@example.com",
			"type": "string"
		},
		{
			"key": "register_phone_number",
			"value": "+573001234567",
			"type": "string"
		},
		{
			"key": "register_password",
			"value": "Str0ng!Pass",
			"type": "string"
		},
		{
			"key": "verification_code",
			"value": "123456",
			"type": "string"
		}
	]
}
