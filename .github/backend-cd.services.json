{
  "services": [
    {
      "service_name": "authservice",
      "service_folder": "Backend/authservice",
      "dockerfile_path": "Backend/authservice/Dockerfile",
      "ecr_repository": "authservice",
      "deployment_manifest": "Infraestructura/k8s/aws/authservice-deployment.yaml",
      "service_manifest": "Infraestructura/k8s/aws/authservice-service.yaml",
      "healthcheck_path": "/",
      "watch_paths": [
        "Backend/authservice/",
        "Infraestructura/k8s/aws/authservice-"
      ]
    },
    {
      "service_name": "search",
      "service_folder": "Backend/search",
      "dockerfile_path": "Backend/search/Dockerfile",
      "ecr_repository": "search",
      "deployment_manifest": "Infraestructura/k8s/aws/search-deployment.yaml",
      "service_manifest": "Infraestructura/k8s/aws/search-service.yaml",
      "healthcheck_path": "/health",
      "watch_paths": [
        "Backend/search/",
        "Infraestructura/k8s/aws/search-"
      ]
    }
  ]
}
