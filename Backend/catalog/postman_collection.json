            "description": "Obtiene todas las propiedades"
          },
          "response": []
        },
        {
          "name": "Get Property by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/properties/{{property_id}}",
              "host": ["{{base_url}}"],
              "path": ["properties", "{{property_id}}"]
            },
            "description": "Obtiene los detalles de una propiedad específica"
          },
          "response": []
        }
      ]
    },
