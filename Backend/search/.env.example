# Plantilla de variables de entorno para el microservicio search.
# Copiar este archivo a .env y ajustar los valores:
#   cp .env.example .env
#
# El archivo .env NO se versiona en git.

# ── Motor de repositorio ───────────────────────────────────────────────────────
# Valores posibles: "postgres" u "opensearch"
REPOSITORY_TYPE=postgres

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Dentro de Docker Compose usar "postgres" como host (nombre del servicio).
# En local usar "localhost".
DB_HOST=postgres
DB_PORT=5432
DB_NAME=travelhub
DB_USER=travelhub
DB_PASSWORD=travelhub

# ── OpenSearch (solo necesario si REPOSITORY_TYPE=opensearch) ─────────────────
#OPENSEARCH_ENDPOINT=https://opensearch:9200
#OPENSEARCH_INDEX=hospedajes
#OPENSEARCH_USER=admin
#OPENSEARCH_PASSWORD=MyStr0ng!Pass#2026
#OPENSEARCH_VERIFY_CERTS=false
