{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStateBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::travelhub-tfstate-dev-us-east-1"
    },
    {
      "Sid": "AccessContainerRegistryStateAndLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::travelhub-tfstate-dev-us-east-1/container_registry/dev/terraform.tfstate*"
    },
    {
      "Sid": "AccessEksStateAndLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::travelhub-tfstate-dev-us-east-1/eks/dev/terraform.tfstate*"
    },
    {
      "Sid": "AccessIngressStateAndLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::travelhub-tfstate-dev-us-east-1/ingress/dev/terraform.tfstate*"
    }
  ]
}
