  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8001/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8001",
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Inventory Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-PMS-Provider",
            "value": "mock",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"hotel_code\": \"COL-HOTE-001\",\n  \"room_type_code\": \"RM001\",\n  \"date\": \"2026-05-15\",\n  \"total_units\": 10,\n  \"available_units\": 3,\n  \"last_modified\": \"{{$isoTimestamp}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8001/api/webhooks/inventory",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8001",
          "path": ["api", "webhooks", "inventory"]
        },
        "description": "Simula un push de inventario desde el PMS. El codigo_mapeo_pms se construirá internamente como COL-HOTE-001:RM001 y Catalog lo resolverá al UUID correspondiente."
      },
      "response": []
    }
  ]
